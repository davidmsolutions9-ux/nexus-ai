// Nexus AI — Prisma Schema
// Stack: PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PlanName {
  LITE
  PLUS
  PRO
  MAX
  ENTERPRISE
}

enum SliderPreference {
  ECONOMIC
  AUTO
  PRO
}

enum TransactionType {
  DEBIT
  CREDIT
  REFUND
  EXPIRY
  RECHARGE
}

enum PriceSignal {
  STRATEGIC
  LOAD
  NORMAL
}

enum ProviderStatus {
  ACTIVE
  DEGRADED
  OFFLINE
}

enum SettlementStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum ContextType {
  PREFERENCE
  PROJECT
  RULE
  SUMMARY
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  passwordHash      String
  planId            String
  dailyCreditsUsed  Int              @default(0)
  dailyCreditsLimit Int
  timezone          String           @default("UTC")
  dailyResetAt      DateTime
  sliderPreference  SliderPreference @default(AUTO)
  avatarLevel       Int              @default(0) // 0–3
  planExpiresAt     DateTime?
  stripeCustomerId  String?          @unique
  createdAt         DateTime         @default(now())

  plan         Plan                @relation(fields: [planId], references: [id])
  transactions CreditTransaction[]
  contexts     UserContext[]

  @@index([email])
  @@index([planId])
  @@index([stripeCustomerId])
  @@map("users")
}

model Plan {
  id                   String   @id @default(uuid())
  name                 PlanName @unique
  priceEurCents        Int
  acusPerDay           Int
  creditsPerDay        Int
  multiAgentAllowed    Boolean  @default(false)
  multiAgentDailyLimit Int      @default(0)
  avatarLevel          Int      @default(0) // 0–3
  createdAt            DateTime @default(now())

  users User[]

  @@map("plans")
}

model CreditTransaction {
  id             String            @id @default(uuid())
  userId         String
  type           TransactionType
  acuAmount      Decimal           @db.Decimal(12, 4)
  creditAmount   Decimal           @db.Decimal(12, 4)
  provider       String?
  modelUsed      String?
  tokensConsumed Int?
  sliderMode     SliderPreference?
  estimatedAcu   Decimal?          @db.Decimal(12, 4)
  actualAcu      Decimal?          @db.Decimal(12, 4)
  // null = plan credits; set = recharge credits (expires purchasedAt + 24h)
  expiresAt      DateTime?
  purchasedAt    DateTime?
  createdAt      DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([userId, type])
  @@index([createdAt])
  @@map("credit_transactions")
}

model ProviderPricing {
  id             String         @id @default(uuid())
  provider       String
  model          String
  acuPer1kTokens Decimal        @db.Decimal(10, 6)
  priceSignal    PriceSignal    @default(NORMAL)
  loadMultiplier Decimal        @default(1.0) @db.Decimal(5, 3)
  latencyP95Ms   Int?
  errorRate5Min  Decimal?       @db.Decimal(5, 4) // 0.0000–1.0000
  qualityIndex   Decimal?       @db.Decimal(5, 4) // 0.0000–1.0000
  status         ProviderStatus @default(ACTIVE)
  updatedAt      DateTime       @updatedAt

  @@unique([provider, model])
  @@index([provider])
  @@index([status])
  @@map("provider_pricing")
}

model Settlement {
  id               String           @id @default(uuid())
  provider         String
  settlementPeriod DateTime // start of the period
  totalAcu         Decimal          @db.Decimal(14, 4)
  totalCostReal    Decimal          @db.Decimal(14, 6) // EUR
  xrplTxHash       String?
  status           SettlementStatus @default(PENDING)
  createdAt        DateTime         @default(now())

  @@index([provider])
  @@index([status])
  @@index([settlementPeriod])
  @@map("settlements")
}

model UserContext {
  id               String      @id @default(uuid())
  userId           String
  contextType      ContextType
  contentEncrypted String // AES-256-GCM encrypted JSON
  relevanceScore   Decimal     @default(0.5) @db.Decimal(5, 4)
  lastUsedAt       DateTime    @default(now())
  expiresAt        DateTime?
  createdAt        DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, contextType])
  @@index([userId, relevanceScore(sort: Desc)])
  @@map("user_contexts")
}
