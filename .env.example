# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://nexus_user:nexus_password@localhost:5432/nexus_ai?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_256bit_secret_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_random_256bit_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=...
GROQ_API_KEY=gsk_...
COHERE_API_KEY=...
TOGETHER_API_KEY=...
PERPLEXITY_API_KEY=pplx-...

# ─── Encryption (for UserContext) ─────────────────────────────────────────────
ENCRYPTION_KEY=32_byte_hex_key_for_aes_256_here_change_me
ENCRYPTION_IV_LENGTH=16

# ─── Dynamic Pricing Engine ───────────────────────────────────────────────────
# How often to refresh provider pricing signals (ms)
PRICING_REFRESH_INTERVAL_MS=30000
# Load multiplier ceiling
PRICING_MAX_LOAD_MULTIPLIER=2.5
# Degraded provider error-rate threshold (0–1)
PRICING_DEGRADED_ERROR_THRESHOLD=0.05
# Offline provider error-rate threshold (0–1)
PRICING_OFFLINE_ERROR_THRESHOLD=0.2

# ─── Credit System ────────────────────────────────────────────────────────────
# Conversion: ACUs → Credits  (75 ACU = 100 Credits)
ACU_TO_CREDIT_NUMERATOR=100
ACU_TO_CREDIT_DENOMINATOR=75

# ─── XRPL Settlement ──────────────────────────────────────────────────────────
XRPL_SERVER=wss://xrplcluster.com
XRPL_WALLET_SEED=s...
XRPL_SETTLEMENT_PERIOD_HOURS=24

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
