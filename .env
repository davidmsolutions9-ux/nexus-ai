COHERE_API_KEY=...
TOGETHER_API_KEY=...
PERPLEXITY_API_KEY=pplx-...

# ─── Encryption (for UserContext) ─────────────────────────────────────────────
ENCRYPTION_KEY=32_byte_hex_key_for_aes_256_here_change_me
ENCRYPTION_IV_LENGTH=16

# ─── Dynamic Pricing Engine ───────────────────────────────────────────────────
# How often to refresh provider pricing signals (ms)
PRICING_REFRESH_INTERVAL_MS=30000
# Load multiplier ceiling
PRICING_MAX_LOAD_MULTIPLIER=2.5
# Degraded provider error-rate threshold (0–1)
PRICING_DEGRADED_ERROR_THRESHOLD=0.05
# Offline provider error-rate threshold (0–1)
PRICING_OFFLINE_ERROR_THRESHOLD=0.2

# ─── Credit System ────────────────────────────────────────────────────────────
# Conversion: ACUs → Credits  (75 ACU = 100 Credits)
ACU_TO_CREDIT_NUMERATOR=100
ACU_TO_CREDIT_DENOMINATOR=75
ACU_TO_CREDIT_RATIO="1.333"

# ─── Daily Reset Cron ─────────────────────────────────────────────────────────
DAILY_RESET_CRON="0 0 * * *"

# ─── XRPL Settlement ──────────────────────────────────────────────────────────
XRPL_SERVER=wss://xrplcluster.com
XRPL_WALLET_SEED=s...
XRPL_SETTLEMENT_PERIOD_HOURS=24

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://diane-represents-saves-sapphire.trycloudflare.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://wqapewaukxakznfcmfni.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_r99pfydHRvQcMRVK7__GNw_uTwku1f-

# ─── Logging ──────────────────────────────────────────────────────────────────
