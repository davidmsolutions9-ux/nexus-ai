# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
# Puerto 5432 directo solo tiene IPv6 — Node no alcanza. Usamos el Session Pooler (IPv4).
# El usuario debe ir a Supabase → Settings → Database → Connection Pooling
# y pegar aquí la "Session mode" URI (puerto 5432 del pooler, no del servidor directo).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexus_ai"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="nexus-ai-jwt-secret-cambiar-en-produccion-2026"
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_random_256bit_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=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
